{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "System.Net.Http.HttpClient": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "SmartCropAPI",
    "Audience": "SmartCropUsers"
  },
  "AI": {
    "OnnxModelPath": "/app/AIModels/model.onnx",
    "AgriVisionApiKey": "${AGRIVISION_API_KEY}"
  },
  "AgriVision": {
    "EngineRevision": "v3-ensemble",
    "ServiceTier": "premium"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      }
    }
  }
}
